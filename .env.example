# ── Supabase (REQUIRED) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Google Gemini AI (REQUIRED for AI features) ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Admin (REQUIRED) ──
ADMIN_PASSWORD=your-admin-password-here

# ── Session (REQUIRED) ──
SESSION_SECRET=your-session-secret-here
# DATABASE_URL enables persistent sessions (survives server restarts)
# Get from Supabase → Project Settings → Database → Connection string (URI mode)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-region.pooler.supabase.com:5432/postgres

# ── Google OAuth (OPTIONAL — only if using Google sign-in) ──
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Server (OPTIONAL) ──
# PORT=8001
# NODE_ENV=production
# PRIMARY_DOMAIN=your-production-domain.com
